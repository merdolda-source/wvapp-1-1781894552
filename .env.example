# Copy this file to .env and fill in real values.

APP_URL=https://example.com
APP_MAX_APPS_PER_USER=5

# The account with this email gets access to the hidden /admin panel
# (all users, all apps, platform-wide stats). Must match exactly the email
# the account registered/logged in with (case-insensitive).
ADMIN_EMAIL=

DB_HOST=127.0.0.1
DB_NAME=webviewbuilder
DB_USER=root
DB_PASS=

# Personal Access Token with "repo" + "workflow" scope, generated by the account
# that owns the GitHub repository below. Used to trigger the Android build
# workflow and to download the finished APK/AAB artifacts.
GITHUB_TOKEN=
GITHUB_OWNER=your-github-username-or-org
GITHUB_REPO=this-repository-name
GITHUB_WORKFLOW_FILE=build-app.yml
GITHUB_BRANCH=main

# Google Cloud Console -> OAuth Client (Web application)
# Authorized redirect URI: {APP_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://example.com/auth/google/callback
